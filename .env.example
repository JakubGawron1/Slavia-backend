# Skopiuj do `.env` (lokalnie) lub ustaw w panelu hostingu (Turso/Hugging Face/Render).
# Secrets.toml ma pierwszeństwo nad .env dla wybranych kluczy (patrz main.rs → pick_cfg).

# --- Baza danych ---
# DATABASE_MODE=local
# DATABASE_LOCAL_PATH=.local/slavia.db
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# DATABASE_POOL_SIZE=8

# --- Auth ---
# JWT_SECRET=change-me-in-production  (min. 32 znaki — wymagane przy Turso; start się wywali bez tego)
# ALLOW_CLOUDINARY_DB_BACKUP=1      — tylko izolowany dev; backup DB na Cloudinary zablokowany na Turso
# DISTRIBUTED_THROTTLE=0            — wyłącz SQLite throttle (domyślnie włączony przy Turso)

# --- Cloudinary (uploady zdjęć) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Trener AI (Groq + LLaMA 3.1 70B) ---
# Klucz z https://console.groq.com/keys — tylko backend, nigdy w frontendzie.
# GROQ_API_KEY=
# Model (domyślnie llama-3.1-70b-versatile; fallback: llama-3.3-70b-versatile):
# GROQ_MODEL=llama-3.1-70b-versatile

# --- Opcjonalnie: tor sztangi vision AI (Barbell Lab) ---
# Model vision Groq: llama-3.2-11b-vision-preview
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
#
# Limity toru AI (post_throttle, free tier) — domyślnie:
#   użytkownik: 2 / min, 10 / dzień
#   klub (global): 3 / min, 45 / dzień
# Osobno od czatu Trenera AI (4/min, 40/dzień).

# --- CORS (Axum) — originy po przecinku; domyślnie localhost + cksslavia.vercel.app + preview main ---
# Na Hugging Face Space ustaw w Variables: origin Vercel + localhost dev.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://cksslavia.vercel.app

# --- Logowanie (tracing) ---
# Domyślnie: slavia_backend=info,tower_http=info,info
# RUST_LOG=debug — pełne żądania HTTP + szczegóły wewnętrzne
# RUST_LOG=slavia_backend=debug,tower_http=debug
# SLAVIA_LOG=... — alias gdy RUST_LOG jest zajęty przez inne narzędzia

# --- Rate limiting (multi-instance) ---
# DISTRIBUTED_THROTTLE=1 — limiter kontakt + publiczny czat AI w SQLite/Turso (`rate_limit_hits`).
# Domyślnie: in-memory `post_throttle` (per proces). Przy starcie z distributed: prune wpisów >48h.

# --- Observability (Prometheus stub, OBS-1) ---
# PROMETHEUS_METRICS=1 — rejestruje GET /metrics (root, nie /api) + middleware liczników HTTP.
# Wartości: 1 | true | yes | on (domyślnie wyłączone).
# Eksport: slavia_http_requests_total, slavia_http_errors_total (text/plain, bez auth).
# Nie mylić z GET /api/system/metrics (JSON KPI, JWT trener+).
# HF Space: ustaw w Variables; scraper zewnętrzny (Prometheus/Grafana Cloud) — patrz docs/OBSERVABILITY.md.

# --- Dev only ---
# REBUILD_DB=true
